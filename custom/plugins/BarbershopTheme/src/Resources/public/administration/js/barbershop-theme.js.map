export default "{% block barbershop_barber_list %}\r\n<sw-page class=\"barbershop-barber-list\">\r\n    {% block barbershop_barber_list_smart_bar_header %}\r\n    <template #smart-bar-header>\r\n        <h2>\r\n            {{ $tc('barbershop-barber.list.title') }}\r\n        </h2>\r\n    </template>\r\n    {% endblock %}\r\n\r\n    {% block barbershop_barber_list_smart_bar_actions %}\r\n    <template #smart-bar-actions>\r\n        {% block barbershop_barber_list_smart_bar_actions_add %}\r\n        <sw-button\r\n            :routerLink=\"{ name: 'barbershop.barber.create' }\"\r\n            variant=\"primary\"\r\n        >\r\n            {{ $tc('barbershop-barber.list.buttonAddBarber') }}\r\n        </sw-button>\r\n        {% endblock %}\r\n    </template>\r\n    {% endblock %}\r\n\r\n    {% block barbershop_barber_list_content %}\r\n    <template #content>\r\n        {% block barbershop_barber_list_grid %}\r\n        <sw-entity-listing\r\n            v-if=\"barbers\"\r\n            :items=\"barbers\"\r\n            :repository=\"repository\"\r\n            :showSelection=\"false\"\r\n            :columns=\"columns\"\r\n            detailRoute=\"barbershop.barber.detail\"\r\n            @delete-item-finish=\"getList\"\r\n        >\r\n        </sw-entity-listing>\r\n        {% endblock %}\r\n    </template>\r\n    {% endblock %}\r\n</sw-page>\r\n{% endblock %}\r\n";