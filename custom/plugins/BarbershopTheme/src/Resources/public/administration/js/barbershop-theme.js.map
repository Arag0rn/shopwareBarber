export default "{% block barbershop_barber_detail %}\r\n<sw-page class=\"barbershop-barber-detail\">\r\n    {% block barbershop_barber_detail_header %}\r\n    <template #smart-bar-header>\r\n        <h2>{{ isCreateMode ? $tc('barbershop-barber.detail.titleCreate') : $tc('barbershop-barber.detail.titleEdit') }}</h2>\r\n    </template>\r\n    {% endblock %}\r\n\r\n    {% block barbershop_barber_detail_actions %}\r\n    <template #smart-bar-actions>\r\n        {% block barbershop_barber_detail_actions_cancel %}\r\n        <sw-button @click=\"onClickCancel\">\r\n            {{ $tc('barbershop-barber.detail.buttonCancel') }}\r\n        </sw-button>\r\n        {% endblock %}\r\n\r\n        {% block barbershop_barber_detail_actions_save %}\r\n        <sw-button-process\r\n            class=\"barbershop-barber-detail__save-action\"\r\n            :isLoading=\"isLoading\"\r\n            :processSuccess=\"processSuccess\"\r\n            variant=\"primary\"\r\n            @process-finish=\"saveFinish\"\r\n            @click=\"onClickSave\"\r\n        >\r\n            {{ $tc('barbershop-barber.detail.buttonSave') }}\r\n        </sw-button-process>\r\n        {% endblock %}\r\n    </template>\r\n    {% endblock %}\r\n\r\n    {% block barbershop_barber_detail_content %}\r\n    <template #content>\r\n        <sw-card-view>\r\n            {% block barbershop_barber_detail_content_card %}\r\n            <sw-card v-if=\"barber\" :isLoading=\"isLoading\">\r\n                {% block barbershop_barber_detail_content_field_name %}\r\n                <sw-text-field\r\n                    v-model=\"barber.name\"\r\n                    :label=\"$tc('barbershop-barber.detail.labelName')\"\r\n                    :placeholder=\"$tc('barbershop-barber.detail.placeholderName')\"\r\n                    required\r\n                    validation=\"required\"\r\n                >\r\n                </sw-text-field>\r\n                {% endblock %}\r\n\r\n                {% block barbershop_barber_detail_content_field_position %}\r\n                <sw-text-field\r\n                    v-model=\"barber.position\"\r\n                    :label=\"$tc('barbershop-barber.detail.labelPosition')\"\r\n                    :placeholder=\"$tc('barbershop-barber.detail.placeholderPosition')\"\r\n                >\r\n                </sw-text-field>\r\n                {% endblock %}\r\n\r\n                {% block barbershop_barber_detail_content_field_media %}\r\n                <sw-upload-listener\r\n                    :uploadTag=\"barber.id\"\r\n                    autoUpload\r\n                    @media-upload-finish=\"setMediaItem\"\r\n                >\r\n                </sw-upload-listener>\r\n                <sw-media-upload-v2\r\n                    variant=\"regular\"\r\n                    :label=\"$tc('barbershop-barber.detail.labelPhoto')\"\r\n                    :uploadTag=\"barber.id\"\r\n                    :source=\"barber.mediaId\"\r\n                    @media-upload-sidebar-open=\"onOpenMediaModal\"\r\n                    @media-upload-remove-image=\"onUnlinkLogo\"\r\n                >\r\n                </sw-media-upload-v2>\r\n                {% endblock %}\r\n\r\n                {% block barbershop_barber_detail_content_field_instagram %}\r\n                <sw-text-field\r\n                    v-model=\"barber.instagram\"\r\n                    :label=\"$tc('barbershop-barber.detail.labelInstagram')\"\r\n                    :placeholder=\"$tc('barbershop-barber.detail.placeholderInstagram')\"\r\n                >\r\n                </sw-text-field>\r\n                {% endblock %}\r\n\r\n                {% block barbershop_barber_detail_content_field_facebook %}\r\n                <sw-text-field\r\n                    v-model=\"barber.facebook\"\r\n                    :label=\"$tc('barbershop-barber.detail.labelFacebook')\"\r\n                    :placeholder=\"$tc('barbershop-barber.detail.placeholderFacebook')\"\r\n                >\r\n                </sw-text-field>\r\n                {% endblock %}\r\n            </sw-card>\r\n            {% endblock %}\r\n        </sw-card-view>\r\n    </template>\r\n    {% endblock %}\r\n</sw-page>\r\n{% endblock %}\r\n";